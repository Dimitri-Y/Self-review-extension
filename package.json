{
  "name": "self-review",
  "displayName": "Self Review",
  "description": "Review your own changes: set a baseline, see added lines highlighted, approve or reject changes.",
  "version": "1.0.3",
  "license": "ISC",
  "engines": {
    "vscode": "^1.60.0"
  },
  "main": "extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:selfReview.startForFile",
    "onCommand:selfReview.approveForFile",
    "onCommand:selfReview.rejectBlockForFile",
    "onCommand:selfReview.stopForFile"
  ],
  "contributes": {
    "commands": [
      {
        "command": "selfReview.startForFile",
        "title": "Self Review: Start (set baseline)"
      },
      {
        "command": "selfReview.approveForFile",
        "title": "Self Review: Approve changes (new baseline)"
      },
      {
        "command": "selfReview.rejectBlockForFile",
        "title": "Self Review: Reject all (revert to baseline)"
      },
      {
        "command": "selfReview.stopForFile",
        "title": "Self Review: Stop (clear baseline)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "selfReview.startForFile",
          "when": "editorTextFocus",
          "group": "selfReview@1"
        },
        {
          "command": "selfReview.approveForFile",
          "when": "editorTextFocus",
          "group": "selfReview@2"
        },
        {
          "command": "selfReview.rejectBlockForFile",
          "when": "editorTextFocus",
          "group": "selfReview@3"
        }
      ],
      "commandPalette": [
        {
          "command": "selfReview.startForFile"
        },
        {
          "command": "selfReview.approveForFile"
        },
        {
          "command": "selfReview.rejectBlockForFile"
        },
        {
          "command": "selfReview.stopForFile"
        }
      ]
    },
    "configuration": {
      "title": "Self Review",
      "properties": {
        "selfReview.decorationBackgroundColor": {
          "type": "string",
          "default": "rgba(0, 255, 0, 0.15)",
          "description": "Background color for added lines (CSS rgba or hex)."
        },
        "selfReview.statusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Self Review status in the status bar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && npx @vscode/vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/vscode": "^1.60.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5"
  }
}